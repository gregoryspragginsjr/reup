{% import "macros.twig" as macros %}

{% if in_component_library %}
  {% set context = '@context' %}
  {% set contextSection = '@context-section' %}
{% else %}
  {% set context = 'context.twig' %}
  {% set contextSection = 'context-section.twig' %}
{% endif %}

<div class="benefits-grid benefits-grid--{{ type|default('default') }}">
  {% if heading or paragraphs or buttons %}
    {% include contextSection with {
      align: 'left',
      size: 'medium',
      subheading: subheading,
      heading: heading,
      paragraphs: paragraphs,
      btnType: 'hollow-indigo',
      buttons: buttons
    } %}
  {% endif %}
  <div class="benefits-grid__inner grid">
    {% for item in items %}
      <div class="benefits-grid__item">
        <div class="benefits-grid__card">
          {% if item.image %}
            <div class="benefits-grid__icon">
              {{ macros.picture(
                'w-full object-cover',
                item.image.srcset,
                item.image.src,
                item.image.sizes.Square,
                item.image.sizes.Square,
                item.image.alt,
                in_component_library
              ) }}
            </div>
          {% endif %}
          {% include context with {
            type: 'default',
            size: 'xsmall',
            align: align,
            subheading: item.subheading,
            tags: false,
            heading: item.heading,
            paragraphs: item.paragraphs,
            buttons: {
              size: 'default',
              type: 'text-indigo',
              items: item.buttons,
            }
          } %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>