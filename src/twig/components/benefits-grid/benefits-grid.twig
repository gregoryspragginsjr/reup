{% if in_component_library %}
  {% set context = '@context' %}
  {% set contextSection = '@context-section' %}
{% else %}
  {% set context = 'context.twig' %}
  {% set contextSection = 'context-section.twig' %}
{% endif %}

<div class="benefits-grid">
  {% include contextSection with {
    size: 'medium',
    subheading: subheading,
    heading: heading,
    paragraphs: paragraphs,
    btnType: 'hollow-indigo',
    buttons: buttons
  } %}
  <div class="benefits-grid__inner grid">
    {% for item in items %}
      <div class="benefits-grid__item">
        <div class="benefits-grid__card">
          {% include context with {
            type: 'default',
            size: 'xsmall',
            align: 'left',
            subheading: item.subheading,
            tags: false,
            heading: item.heading,
            paragraphs: item.paragraphs,
            buttons: {
              size: 'default',
              type: 'text-indigo',
              items: item.buttons,
            }
          } %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>