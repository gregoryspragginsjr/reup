{% macro icon(name, class) %}
  {% if name == 'home' %}
    <svg class="{{ class }}" viewBox="0 0 11.2 11.2" style="enable-background:new 0 0 11.2 11.2" xml:space="preserve">
      <path d="M6.1.2c-.3-.3-.7-.3-1 0L.2 5.1c-.3.3-.3.7 0 1 .3.3.7.3 1 0l.2-.2v4.6c0 .4.3.7.7.7h1.4c.4 0 .7-.3.7-.7V9.1c0-.4.3-.7.7-.7h1.4c.4 0 .7.3.7.7v1.4c0 .4.3.7.7.7h1.4c.4 0 .7-.3.7-.7V5.9l.2.2c.3.3.7.3 1 0 .3-.3.3-.7 0-1L6.1.2z" />
    </svg>
  {% elseif name == 'play' %}
    <svg class="{{ class }}" style="enable-background:new 0 0 16 24" viewBox="0 0 16 24">
      <path d="M15.8 11.6c.3.2.3.7 0 .9L.8 24c-.3.3-.8 0-.8-.4V.5C0 .1.5-.2.8.1l15 11.5z" />
    </svg>
  {% elseif name == 'chevron-arrow' %}
    <svg class="{{ class }}" style="enable-background:new 0 0 10 6" viewBox="0 0 10 6">
      <path d="M.3.3c.4-.4 1-.4 1.4 0L5 3.6 8.3.3c.4-.4 1-.4 1.4 0 .4.4.4 1 0 1.4l-4 4c-.4.4-1 .4-1.4 0l-4-4C-.1 1.3-.1.7.3.3z" style="fill-rule:evenodd; clip-rule:evenodd;" />
    </svg>
  {% endif %}
{% endmacro %}
